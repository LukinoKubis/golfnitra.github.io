        <li><a href="https://www.kartoma.sk" target="_blank" rel="noopener">Kartoma ↗</a></li>
        <li><a href="https://www.skg.sk" target="_blank" rel="noopener">SKG ↗</a></li>
        <li><a href="https://www.pgacz.com" target="_blank" rel="noopener">PGA of Czech Republic ↗</a></li>
      </ul>
    </div>
  </div>

  <div class="footer__bottom container">
    <span class="footer__copy">© {{ site.club_name }}</span>
    <span class="footer__partner">
      Hlavný partner: <a href="https://www.kartoma.sk" target="_blank" rel="noopener">Kartoma</a>
    </span>
