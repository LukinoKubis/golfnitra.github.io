<footer class="footer">
  <div class="footer__grid container">
    <div class="footer__brand">
      <img src="/img/logo-white.png" alt="Green Meadows Golf" class="footer__logo">
      <p class="footer__brand-text">
        Golfové ihrisko GREEN MEADOWS &amp; GREEN PARK<br>
        Ivanka pri Nitre — NO TEETIME NO STRESS
      </p>
      <div class="footer__socials" style="margin-top:2rem;">
        <a href="{{ site.facebook }}" target="_blank" rel="noopener">Facebook</a>
        <a href="{{ site.youtube }}" target="_blank" rel="noopener">YouTube</a>
      </div>
    </div>

    <div class="footer__contact">
      <div class="footer__col-title">Kontakt</div>
      <p>
        Ábelova ul., 951 12 Ivanka pri Nitre<br>
        <a href="tel:{{ site.phone }}">{{ site.phone }}</a><br>
        <a href="mailto:{{ site.email }}">{{ site.email }}</a>
      </p>
      <p style="margin-top:1.5rem;">
        <strong style="color:rgba(255,255,255,.65);">GK Meander o.z.</strong><br>
        IČO: {{ site.ico_klub }}<br>
        IBAN: {{ site.iban }}
      </p>
    </div>

    <div>
      <div class="footer__col-title">Rýchle odkazy</div>
      <ul class="footer__links">
        <li><a href="/cennik/">Cenník 2026</a></li>
        <li><a href="/gk-meander/">Členstvo</a></li>
        <li><a href="/golfove-ihrisko/">Ihrisko</a></li>
        <li><a href="/info-blok/treningy-zelene-karty/">Tréningy</a></li>
        <li><a href="/golfove-ihrisko/hole-in-one/">Hole in One &amp; Eagle</a></li>
        <li><a href="/gk-meander/majstri-klubu/">Majstri klubu</a></li>
        <li><a href="/kontakt/">Kontakt</a></li>
      </ul>
    </div>

    <div>
      <div class="footer__col-title">Partneri</div>
