---
layout: layouts/base.njk
title: "Majstri klubu"
permalink: /gk-meander/majstri-klubu/
---
<section class="hero hero--inner">
  <div class="hero__bg"></div>
  <div class="hero__content">
    <p class="hero__eyebrow">GK Meander</p>
    <h1 class="hero__title">Majstri klubu</h1>
    <p class="hero__sub">História víťazov</p>
  </div>
</section>

<section class="section">
  <div class="container--sm">
    <div class="section-header">
      <span class="section-label">Tradícia</span>
      <h2 class="section-title">Klubové majstrovstvá</h2>
      <p class="section-sub">História víťazov klubových majstrovstiev GK Meander od roku 2018.</p>
    </div>

    <div class="champions-list">
      {% for year in club_champions.years | reverse %}
      <div class="champion-year">
        <div class="champion-year__num">{{ year.year }}</div>
        <div class="champion-year__tournaments">
          {% for t in year.tournaments %}
          <div class="tournament-block">
            <div class="tournament-block__name">{{ t.name }}</div>
            {% if t.date %}<div class="tournament-block__date">{{ t.date }}</div>{% endif %}
            {% for r in t.results %}
            <div class="tournament-result">
              <span class="tournament-result__cat">{{ r.category }}</span>
              <span>
                <span class="tournament-result__winner">{{ r.winner }}</span>
                {% if r.score %}<span class="tournament-result__score">({{ r.score }})</span>{% endif %}
              </span>
            </div>
            {% endfor %}
          </div>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
