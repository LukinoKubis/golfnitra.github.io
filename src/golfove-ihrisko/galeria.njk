<section class="hero hero--inner hero--houses">
  <div class="hero__bg"></div>
  <div class="hero__content">
    <p class="hero__eyebrow">Golfové ihrisko</p>
    <h1 class="hero__title">Galéria</h1>
    <p class="hero__sub">Vývoj ihriska</p>
  </div>
</section>

<section class="section">
  <div class="container--sm">
    <div class="section-header">
      <span class="section-label">Fotografie</span>
      <h2 class="section-title">Galéria vývoja ihriska</h2>
      <p class="section-sub">
        Fotogaléria dokumentuje vznik a vývoj golfového areálu GREEN MEADOWS a GREEN PARK od jeho počiatkov.
        Fotografie budú priebežne dopĺňané.
      </p>
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(28rem,1fr));gap:2rem;">
      <img src="/img/gm1.jpg" alt="Aerial drone — Green Meadows" style="width:100%;height:22rem;object-fit:cover;" loading="lazy">
      <img src="/img/gm2.jpg" alt="Aerial drone — Green Meadows 2" style="width:100%;height:22rem;object-fit:cover;" loading="lazy">
      <img src="/img/gm3.jpg" alt="Aerial drone — Green Park" style="width:100%;height:22rem;object-fit:cover;" loading="lazy">
      <img src="/img/gm4.jpg" alt="Aerial drone — overview" style="width:100%;height:22rem;object-fit:cover;" loading="lazy">
      <img src="/img/houses.jpg" alt="Areál" style="width:100%;height:22rem;object-fit:cover;" loading="lazy">
      <img src="/img/houses2.jpg" alt="Areál 2" style="width:100%;height:22rem;object-fit:cover;" loading="lazy">
    </div>

    <p style="margin-top:3rem;font-size:1.4rem;color:var(--text-muted);">
      Ďalšie fotografie z histórie ihriska nájdete na
      <a href="{{ site.facebook }}" target="_blank" rel="noopener" style="color:var(--green-accent);">Facebooku GK Meander</a>.
    </p>
  </div>
</section>
