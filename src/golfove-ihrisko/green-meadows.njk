---
layout: layouts/base.njk
title: "9-jamkové ihrisko Green Meadows"
permalink: /golfove-ihrisko/green-meadows/
---
{% set course = null %}
{% for c in collections.courses %}
  {% if c.data.slug == "green-meadows" %}{% set course = c %}{% endif %}
{% endfor %}

<section class="hero hero--inner hero--gm">
  <div class="hero__bg"></div>
  <div class="hero__content">
    <p class="hero__eyebrow">9-jamkové ihrisko</p>
    <h1 class="hero__title">Green Meadows</h1>
  </div>
</section>

<section class="section">
  <div class="container--sm">
    <div class="notice">
      <strong>2026:</strong> Ihriská GREEN MEADOWS a GREEN PARK sa striedajú — sledujte značenie pri vstupe do areálu.
    </div>

    {% if course %}
    <div class="section-header">
      <span class="section-label">Parametre</span>
      <h2 class="section-title">Vybavenie ihriska</h2>
    </div>

    <ul class="page-body" style="padding:0;">
      {% for f in course.data.features %}
      <li>{{ f }}</li>
      {% endfor %}
    </ul>

    <div class="section-header" style="margin-top:5rem;">
      <h2 class="section-title">Mapa ihriska</h2>
    </div>
    <img src="{{ course.data.course_map }}" alt="Mapa 9-jamkového ihriska Green Meadows 2026" style="max-width:100%;height:auto;border:.1rem solid var(--border);" loading="lazy">

    <div class="page-body" style="margin-top:3rem;">
      {{ course.templateContent | safe }}
    </div>
    {% endif %}

    <p style="margin-top:4rem;">
      <a href="/cennik/" class="btn btn--green">Zobraziť cenník →</a>
      <a href="/golfove-ihrisko/green-park/" class="btn btn--outline-green" style="margin-left:1.5rem;">Green Park →</a>
    </p>
  </div>
</section>
