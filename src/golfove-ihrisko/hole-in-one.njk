---
layout: layouts/base.njk
title: "Hole in One & Eagle"
permalink: /golfove-ihrisko/hole-in-one/
---
<section class="hero hero--inner">
  <div class="hero__bg"></div>
  <div class="hero__content">
    <p class="hero__eyebrow">Naše ihrisko</p>
    <h1 class="hero__title">Hole in One</h1>
    <p class="hero__sub">Eagle &amp; Albatros</p>
  </div>
</section>

<section class="section">
  <div class="container--sm">
    <div class="section-header">
      <span class="section-label">Rekordy</span>
      <h2 class="section-title">Hole-in-One, Eagle, Albatros</h2>
      <p class="section-sub">{{ hole_in_one.note }}</p>
    </div>

    <div class="records-section">
      <div class="records-section__title">Nesúťažný Hole-in-One</div>
      <table class="pricing-table">
        <thead>
          <tr><th>Dátum</th><th>Hráč/-ka</th><th>Jamka</th><th>Vzdialenosť</th></tr>
        </thead>
        <tbody>
          {% for r in hole_in_one.hole_in_one_nesuazny %}
          <tr>
            <td>{{ r.date }}</td>
            <td>{{ r.player }}</td>
            <td>{{ r.hole }}</td>
            <td>{{ r.distance }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class="records-section">
      <div class="records-section__title">Súťažný Hole-in-One</div>
      {% if hole_in_one.hole_in_one_suazny | length %}
      <table class="pricing-table">
        <thead>
          <tr><th>Dátum</th><th>Hráč/-ka</th><th>Jamka</th><th>Vzdialenosť</th></tr>
        </thead>
        <tbody>
          {% for r in hole_in_one.hole_in_one_suazny %}
          <tr><td>{{ r.date }}</td><td>{{ r.player }}</td><td>{{ r.hole }}</td><td>{{ r.distance }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <p style="color:var(--text-muted);font-size:1.5rem;">(bez zaznamenaných výsledkov)</p>
      {% endif %}
    </div>

    <div class="records-section">
      <div class="records-section__title">Eagle</div>
      <table class="pricing-table">
        <thead>
          <tr><th>Dátum</th><th>Hráč/-ka</th><th>Jamka</th><th>Poznámka</th></tr>
        </thead>
        <tbody>
          {% for r in hole_in_one.eagle %}
          <tr>
            <td>{{ r.date }}</td>
            <td>{{ r.player }}</td>
            <td>{{ r.hole }}</td>
            <td>{{ r.note }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>

    <div class="records-section">
      <div class="records-section__title">Albatros</div>
      {% if hole_in_one.albatros | length %}
      <table class="pricing-table">
        <thead>
          <tr><th>Dátum</th><th>Hráč/-ka</th><th>Jamka</th><th>Poznámka</th></tr>
        </thead>
        <tbody>
          {% for r in hole_in_one.albatros %}
          <tr><td>{{ r.date }}</td><td>{{ r.player }}</td><td>{{ r.hole }}</td><td>{{ r.note }}</td></tr>
          {% endfor %}
        </tbody>
      </table>
      {% else %}
      <p style="color:var(--text-muted);font-size:1.5rem;">(žiadny záznam)</p>
      {% endif %}
    </div>
  </div>
</section>
