---
layout: layouts/base.njk
title: "Info-blok"
permalink: /info-blok/
---
<section class="hero hero--inner">
  <div class="hero__bg"></div>
  <div class="hero__content">
    <h1 class="hero__title">Info-blok</h1>
    <p class="hero__sub">Užitočné informácie pre hráčov</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-header section-header--center">
      <span class="section-label">Informácie</span>
      <h2 class="section-title">Čo tu nájdete</h2>
      <p class="section-sub">Užitočné informácie pre hráčov a záujemcov o golf na ihrisku Green Meadows.</p>
    </div>

    <div class="quicklinks-grid">
      {% for item in collections.pages %}
      <a href="{{ item.data.permalink }}" class="quicklink">
        <div class="quicklink__title">{{ item.data.title }}</div>
      </a>
      {% endfor %}
      <a href="/rezervacia/" class="quicklink">
        <span class="quicklink__icon">📅</span>
        <div class="quicklink__title">Rezervácia tréningu</div>
        <div class="quicklink__desc">Online rezervácia termínu tréningu u nášho PGA trénera</div>

      </a>
    </div>
  </div>
</section>
