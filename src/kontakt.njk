---
layout: layouts/base.njk
title: "Kontakt"
permalink: /kontakt/
---
<section class="hero hero--inner">
  <div class="hero__bg"></div>
  <div class="hero__content">
    <h1 class="hero__title">Kontakt</h1>
  </div>
</section>

<section class="section">
  <div class="container--sm">
    <div class="section-header">
      <span class="section-label">Nájdite nás</span>
      <h2 class="section-title">Kontaktné informácie</h2>
    </div>

    <div class="contact-grid">
      <div class="contact-block">
        <div class="contact-block__title">Golfové ihrisko</div>
        <address>
          <strong>GREEN MEADOWS &amp; GREEN PARK</strong><br>
          {{ site.address_ihrisko }}<br>
          Tel.: <a href="tel:{{ site.phone }}">{{ site.phone }}</a><br>
          E-mail: <a href="mailto:{{ site.email }}">{{ site.email }}</a>
        </address>
      </div>

      <div class="contact-block">
        <div class="contact-block__title">Golfový klub MEANDER o.z.</div>
        <address>
          {{ site.address_klub }}<br>
          IČO: {{ site.ico_klub }}<br>
          Prezident: {{ site.president }}<br>
          Tel.: <a href="tel:{{ site.phone }}">{{ site.phone }}</a><br>
          E-mail: <a href="mailto:{{ site.email }}">{{ site.email }}</a>
        </address>
      </div>

      <div class="contact-block">
        <div class="contact-block__title">GM-Golf s.r.o. (prevádzka ihriska)</div>
        <address>
          {{ site.address_klub }}<br>
          IČO: {{ site.ico_prevadzka }}<br>
          Tel.: <a href="tel:{{ site.phone }}">{{ site.phone }}</a><br>
          E-mail: <a href="mailto:{{ site.email }}">{{ site.email }}</a>
        </address>
      </div>

      <div class="contact-block">
        <div class="contact-block__title">Bankové spojenie</div>
        <address>
          <strong>GK Meander o.z. (členstvo)</strong><br>
          Tatra banka a.s.<br>
          č.ú. {{ site.bank_klub }}<br>
          IBAN: {{ site.iban }}<br>
          <br>
          <strong>GM-Golf s.r.o. (green fee)</strong><br>
          Tatra banka a.s.<br>
          č.ú. {{ site.bank_prevadzka }}
        </address>
      </div>
    </div>

    <div class="section-header" style="margin-top:6rem;">
      <h2 class="section-title">Sledujte nás</h2>
    </div>
    <p style="font-size:1.6rem;color:var(--text-mid);line-height:2;">
      <a href="{{ site.facebook }}" target="_blank" rel="noopener" style="color:var(--green-accent);">Facebook — Green Meadows golfové ihrisko</a><br>
      <a href="{{ site.youtube }}" target="_blank" rel="noopener" style="color:var(--green-accent);">YouTube — video pozvánka</a>
    </p>

    <div class="section-header" style="margin-top:4rem;">
      <h2 class="section-title">Newsletter</h2>
    </div>
    <p style="font-size:1.6rem;color:var(--text-mid);">
      Záujem o novinky e-mailom? Napíšte nám na
      <a href="mailto:{{ site.email }}" style="color:var(--green-accent);">{{ site.email }}</a>
      a zaradíme Vás do zoznamu odberateľov.
    </p>

    <div style="margin-top:6rem;">
      <iframe
        src="https://maps.google.com/maps?q=48.245575,18.118987&z=17&output=embed"
        width="100%" height="400" style="border:0;display:block;" allowfullscreen="" loading="lazy"
        referrerpolicy="no-referrer-when-downgrade" title="Poloha golfového ihriska Green Meadows"></iframe>
    </div>
  </div>
</section>
